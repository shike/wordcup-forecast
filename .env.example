# football-data.org API key (optional - leave empty to use Wikipedia only)
FOOTBALL_DATA_API_KEY=

# JisuAPI (极速数据) key for Chinese football fixtures/standings/news
# Get one at https://www.jisuapi.com - optional but enables Jisu enrichment
JISU_API_KEY=

# Use offline mode (no network calls) - true/false
OFFLINE_MODE=false

# Output directory
OUTPUT_DIR=./output

# Cache directory
CACHE_DIR=./cache

# Default language: zh, en, bilingual
DEFAULT_LANG=bilingual
